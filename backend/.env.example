# Application
APP_NAME="Gram Panchayat ERP API"
APP_VERSION="1.0.0"
DEBUG=True
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Database
# Use psycopg2 adapter for synchronous or async_pg if we want async. Let's use standard sync/async hybrid.
DATABASE_URL="postgresql://user:password@localhost:5432/grampanchayat"

# Redis & Celery
REDIS_URL="redis://localhost:6379/0"

# Security
SECRET_KEY="YOUR_SUPER_SECRET_KEY_FOR_JWT"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# CORS
BACKEND_CORS_ORIGINS='["http://localhost", "http://localhost:3000"]'
