# Application
APP_NAME="Gram Panchayat ERP API"
APP_VERSION="1.0.0"
DEBUG=True
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Database
DATABASE_URL="postgresql://localhost:5432/grampanchayat"

# Redis & Celery
REDIS_URL="redis://localhost:6379/0"

# Security
SECRET_KEY="YOUR_SUPER_SECRET_KEY_FOR_JWT"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
BACKEND_CORS_ORIGINS='["http://localhost", "http://localhost:3000", "http://localhost:4200"]'
